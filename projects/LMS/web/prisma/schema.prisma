generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  LEARNER
  INSTRUCTOR
  MANAGER
  ADMIN
}

enum PathStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
}

enum ModuleKind {
  LESSON
  QUIZ
}

enum AttemptStatus {
  PASSED
  FAILED
  INCOMPLETE
}

model User {
  id                String            @id @default(uuid())
  name              String
  email             String            @unique
  role              UserRole          @default(LEARNER)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  assignments       PathAssignment[]
  assignedByAssignments PathAssignment[] @relation("PathAssignedBy")
  moduleCompletions ModuleCompletion[]
  pathCompletions   PathCompletion[]
}

model TrainingPath {
  id               String            @id @default(uuid())
  title            String
  description      String
  passingThreshold Int               @default(80)
  status           PathStatus        @default(ASSIGNED)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  modules          Module[]
  assignments      PathAssignment[]
  completions      PathCompletion[]
}

model PathAssignment {
  id            String       @id @default(uuid())
  userId        String
  pathId        String
  assignedById  String?
  assignedAt    DateTime     @default(now())
  completedAt   DateTime?
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  path          TrainingPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  assignedBy    User?        @relation("PathAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([userId, pathId])
}

model Module {
  id          String       @id @default(uuid())
  pathId      String
  title       String
  position    Int
  kind        ModuleKind
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  path        TrainingPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  attempts    AssessmentAttempt[]
  completions ModuleCompletion[]

  @@unique([pathId, position])
}

model AssessmentAttempt {
  id          String   @id @default(uuid())
  moduleId    String
  userId      String
  score       Int
  passed      Boolean
  status      AttemptStatus
  createdAt   DateTime @default(now())
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, moduleId])
}

model ModuleCompletion {
  id          String   @id @default(uuid())
  moduleId    String
  userId      String
  completedAt DateTime @default(now())
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([moduleId, userId])
}

model PathCompletion {
  id          String   @id @default(uuid())
  pathId      String
  userId      String
  passed      Boolean
  completedAt DateTime @default(now())
  path        TrainingPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pathId, userId])
}
